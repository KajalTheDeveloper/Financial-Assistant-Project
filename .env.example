# =============================================================================
# Financial Knowledge Assistant - Environment Configuration
# =============================================================================

# -----------------------------------------------------------------------------
# API Keys (Required)
# -----------------------------------------------------------------------------
OPENAI_API_KEY=your-openai-api-key-here

# Optional: For advanced features
# COHERE_API_KEY=your-cohere-api-key
# HUGGINGFACE_API_KEY=your-hf-api-key

# -----------------------------------------------------------------------------
# Model Configuration
# -----------------------------------------------------------------------------
# LLM Model (Options: gpt-4o-mini, gpt-4o, gpt-3.5-turbo)
LLM_MODEL=gpt-4o-mini

# Embedding Model (Options: BAAI/bge-base-en-v1.5, text-embedding-3-small)
EMBEDDING_MODEL=BAAI/bge-base-en-v1.5

# Reranker Model
RERANKER_MODEL=BAAI/bge-reranker-base

# -----------------------------------------------------------------------------
# RAG Configuration
# -----------------------------------------------------------------------------
# Chunking settings
CHUNK_SIZE=1000
CHUNK_OVERLAP=200

# Retrieval settings
TOP_K_RETRIEVAL=5
INITIAL_RETRIEVAL_K=20
SIMILARITY_THRESHOLD=0.5

# Feature toggles
ENABLE_RERANKING=true
ENABLE_HYBRID_SEARCH=true
ENABLE_QUERY_REWRITING=true

# -----------------------------------------------------------------------------
# Vector Database
# -----------------------------------------------------------------------------
VECTOR_DB_TYPE=chroma
CHROMA_PERSIST_DIR=./data/chroma_db
COLLECTION_NAME=financial_documents

# -----------------------------------------------------------------------------
# Application Settings
# -----------------------------------------------------------------------------
APP_NAME=Financial Knowledge Assistant
APP_ENV=development
DEBUG=true
LOG_LEVEL=INFO

# -----------------------------------------------------------------------------
# API Server (FastAPI)
# -----------------------------------------------------------------------------
API_HOST=0.0.0.0
API_PORT=8000

# -----------------------------------------------------------------------------
# UI Settings (Streamlit)
# -----------------------------------------------------------------------------
STREAMLIT_PORT=8501
MAX_FILE_SIZE_MB=50

# -----------------------------------------------------------------------------
# Evaluation
# -----------------------------------------------------------------------------
ENABLE_EVALUATION_LOGGING=true
EVAL_SAMPLE_SIZE=100
